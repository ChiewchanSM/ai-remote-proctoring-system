# ==========================================
# 1. K-DAI PROCTORING CUSTOM RULES
# ==========================================
# Ignore AI Model Weights (Too large for GitHub, prevents upload crashes)
*.pt

# Ignore the Teacher Database (Contains private student data)
*.db
*.sqlite3
data/*.db

# Ignore Photographic Evidence (Protects student privacy)
data/*.jpg
data/*.png
data/*.csv

# ==========================================
# 2. STANDARD PYTHON JUNK & CACHE
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.so

# Environments & Secrets
.env
venv/
env/
.venv/

# Jupyter Notebook & IDEs
.ipynb_checkpoints/
.vscode/

# OS Generated Files
.DS_Store
Thumbs.db
